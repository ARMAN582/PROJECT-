<a class="card" href="https://www.linkedin.com/in/arman-qureshi-47953b295">LinkedIn</a>
<a class="card" href="https://www.binance.com/en-IN/trade/BTC_USDT">Binance</a>
<a class="card" href="https://in.tradingview.com/chart/">TradingView</a>

</div>

<!-- SUPPORT -->
<a class="support" href="https://wa.me/9026550240">💬</a>

<script>
function updateClock(){
  const now = new Date();

  let h = now.getHours();
  let m = now.getMinutes();
  let s = now.getSeconds();

  h = h < 10 ? "0" + h : h;
  m = m < 10 ? "0" + m : m;
  s = s < 10 ? "0" + s : s;

  document.getElementById("clock").innerText =
    "Time: " + h + ":" + m + ":" + s;
}

setInterval(updateClock, 1000);
updateClock();
</script>

</body>
