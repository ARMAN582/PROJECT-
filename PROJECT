<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Arman Hub</title>

<style>
body{
  margin:0;
  font-family:Arial;
  background:linear-gradient(270deg,#000,#001f1f,#000);
  background-size:400% 400%;
  animation:bg 10s ease infinite;
  color:#fff;
  text-align:center;
}

/* Background animation */
@keyframes bg{
  0%{background-position:0%}
  50%{background-position:100%}
  100%{background-position:0%}
}

/* Header */
h1{
  margin:15px 0 5px;
}

/* Clock */
#clock{
  font-size:18px;
  font-weight:bold;
  margin-bottom:10px;
}

/* Grid */
.grid{
  display:grid;
  grid-template-columns:repeat(2,1fr);
  gap:15px;
  padding:15px;
}

/* Cards */
.card{
  background:rgba(255,255,255,0.08);
  padding:20px;
  border-radius:15px;
  text-decoration:none;
  color:#fff;
  box-shadow:0 0 15px rgba(0,255,0,0.4);
  transition:0.3s;
}

.card:hover{
  transform:scale(1.05);
  box-shadow:0 0 25px #0f0;
}

/* Support Button */
.support{
  position:fixed;
  bottom:20px;
  right:20px;
  background:#25D366;
  padding:15px;
  border-radius:50%;
  font-size:22px;
  text-decoration:none;
  color:#000;
  box-shadow:0 0 20px #0f0;
}
</style>
</head>

<body>

<h1>Arman Qureshi Hub</h1>

<div id="clock">Loading time...</div>

